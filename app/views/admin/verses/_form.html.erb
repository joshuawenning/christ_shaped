<%= form_with model: [:admin, verse ] do |form| %>
  <% if verse.errors.any? %>
    <div>
      <h2><%= pluralize(verse.errors.count, "error") %> prevented saving:</h2>
      <ul>
        <% verse.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :featured_image %>
    <%= form.file_field :featured_image, accept: "image/*", id: "image-upload-input" %>
    <div id="image-preview">
      <% if verse.featured_image.attached? %>
        <%= image_tag verse.featured_image, alt: verse.featured_image_title %>
      <% end %>
    </div>
  </div>

  <div>
    <%= form.label :featured_image_title %><br>
    <%= form.text_field :featured_image_title, value: verse.featured_image_title %>
  </div>

  <div>
    <%= form.label :featured_image_attribution %><br>
    <%= form.text_field :featured_image_attribution, value: verse.featured_image_attribution %>
  </div>

  <div>
    <%= form.label :featured_image_attribution_link %><br>
    <%= form.url_field :featured_image_attribution_link, value: verse.featured_image_attribution_link %>
  </div>

  <div>
    <%= form.label :reference %><br>
    <%= form.text_field :reference %>
  </div>

  <div>
    <%= form.label :scripture %><br>
    <%= form.text_area :scripture %>
  </div>

  <div>
    <%= form.label :body, "Reflection" %><br>
    <%= form.rich_text_area :body %>
  </div>

  <div>
    <%= form.submit verse.persisted? ? "Update Verse" : "Create Verse" %>
    <%= link_to "Cancel", verse.persisted? ? verse_path(verse) : verses_path %>
  </div>
<% end %>

<script>
  document.addEventListener("turbo:load", function() {
    const input = document.getElementById("image-upload-input");
    const preview = document.getElementById("image-preview");

    if (input && preview) {
      input.addEventListener("change", function(event) {
        const file = event.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function(e) {
            preview.innerHTML = "<img src='" + e.target.result + "' alt='Preview'>";
          };
          reader.readAsDataURL(file);
        }
      });
    }
  });
</script>
<h1>Latest Verse</h1>

<% if @verse.present? %>
  <%= image_tag @verse.featured_image, alt: "" if @verse.featured_image.attached? %>
  <h2><%= @verse.reference %></h2>
  <h2>Scripture</h2>
  <p><i><%= @verse.scripture %></i></p>
  <h3>Reflection</h3>
  <p><%= @verse.body %></p>

  <%= link_to "View archive", verses_path %>
<% else %>
  <p>No verses are available yet.</p>
<% end %>
